# Claude Code local settings
.claude/

# Credentials — never commit these
utils/.an_credentials.json
utils/.notifier_credentials.json
tracking/changelog.json

# Tracking data — keep picks.xlsx for monitoring agents, ignore the rest
tracking/*
!tracking/picks.xlsx

# Exported reports — keep .xlsx files inside dated subfolders, ignore everything else
exports/*
!exports/*/
exports/*/*
!exports/*/*.xlsx

# Logs
logs/

# Raw and processed data — large files, pulled by 01_input scripts
data/raw/
data/processed/

# Python
__pycache__/
*.pyc
*.pyo
.DS_Store

# Environment
.env
